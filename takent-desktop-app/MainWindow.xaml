<?xml version="1.0" encoding="utf-8"?>
<Window
    xmlns:local="using:takent_desktop_app"
    x:Class="takent_desktop_app.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="takent">

    <Grid Background="#FFF7ED">
        <Grid.Resources>
            <local:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
            <SolidColorBrush x:Key="TextControlBackground"                    Color="#FDFAF6"/>
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver"         Color="#FAF4EC"/>
            <SolidColorBrush x:Key="TextControlBackgroundFocused"             Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextControlBackgroundDisabled"            Color="#F2ECE3"/>
            <SolidColorBrush x:Key="TextControlBorderBrush"                   Color="#E5DDD4"/>
            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver"        Color="#C6BCB3"/>
            <SolidColorBrush x:Key="TextControlBorderBrushFocused"            Color="#292524"/>
            <SolidColorBrush x:Key="TextControlBorderBrushDisabled"           Color="#E5DDD4"/>
            <SolidColorBrush x:Key="TextControlForeground"                    Color="#292524"/>
            <SolidColorBrush x:Key="TextControlForegroundDisabled"            Color="#B8B3B0"/>
            <SolidColorBrush x:Key="TextControlPlaceholderForeground"         Color="#B8B3B0"/>
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundPointerOver" Color="#9E9994"/>
            <SolidColorBrush x:Key="TextControlPlaceholderForegroundFocused"  Color="#C6BCB3"/>
            <SolidColorBrush x:Key="TextControlSelectionHighlightColor"       Color="#29252440"/>

            <Style x:Key="InputBox" TargetType="TextBox">
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Padding"         Value="13,11"/>
                <Setter Property="FontSize"        Value="14"/>
                <Setter Property="CornerRadius"    Value="10"/>
                <Setter Property="MinHeight"       Value="46"/>
            </Style>

            <Style x:Key="PassBox" TargetType="PasswordBox">
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Padding"         Value="13,11"/>
                <Setter Property="FontSize"        Value="14"/>
                <Setter Property="CornerRadius"    Value="10"/>
                <Setter Property="MinHeight"       Value="46"/>
            </Style>

            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="Foreground" Value="#292524"/>
                <Setter Property="FontSize"   Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin"     Value="0,0,0,7"/>
            </Style>

            <Style x:Key="PrimaryBtn" TargetType="Button">
                <Setter Property="HorizontalAlignment"        Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="Padding"                    Value="0,0"/>
                <Setter Property="FontSize"                   Value="14"/>
                <Setter Property="FontWeight"                 Value="SemiBold"/>
                <Setter Property="MinHeight"                  Value="48"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid MinHeight="{TemplateBinding MinHeight}">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">

                                        <VisualState x:Name="Normal">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="BtnBg"
                                                                Storyboard.TargetProperty="Color"
                                                                To="#292524" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="BtnBorder"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </VisualState>

                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="BtnBg"
                                                                Storyboard.TargetProperty="Color"
                                                                To="#3D3534" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </VisualState>

                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="BtnBg"
                                                                Storyboard.TargetProperty="Color"
                                                                To="#171413" Duration="0:0:0.08"/>
                                                <DoubleAnimation Storyboard.TargetName="BtnBorder"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.85" Duration="0:0:0.08"/>
                                            </Storyboard>
                                        </VisualState>

                                        <VisualState x:Name="Disabled">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="BtnBg"
                                                                Storyboard.TargetProperty="Color"
                                                                To="#C4BCB8" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </VisualState>

                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <Border x:Name="BtnBorder"
                                        CornerRadius="10"
                                        Padding="0,0">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="BtnBg" Color="#292524"/>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"
                                                      Foreground="#FFF7ED"
                                                      FontSize="{TemplateBinding FontSize}"
                                                      FontWeight="{TemplateBinding FontWeight}"
                                                      Content="{TemplateBinding Content}"
                                                      Margin="0,14"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TabBtn" TargetType="Button">
                <Setter Property="HorizontalAlignment"        Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="FontSize"  Value="13"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">

                                        <VisualState x:Name="Normal">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0" Duration="0:0:0.18"/>
                                            </Storyboard>
                                        </VisualState>

                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="1" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </VisualState>

                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                                 Storyboard.TargetProperty="Opacity"
                                                                 To="0.4" Duration="0:0:0.06"/>
                                            </Storyboard>
                                        </VisualState>

                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <Border x:Name="HoverLayer"
                                        CornerRadius="8"
                                        Background="#00000012"
                                        Opacity="0"/>

                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  Foreground="{TemplateBinding Foreground}"
                                                  FontSize="{TemplateBinding FontSize}"
                                                  FontWeight="{TemplateBinding FontWeight}"
                                                  Content="{TemplateBinding Content}"
                                                  Margin="0,9"/>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="SecondaryBtn" TargetType="Button">
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="FontSize"   Value="13"/>
                <Setter Property="FontWeight" Value="Medium"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroup x:Name="CommonStates">

                                        <VisualState x:Name="Normal">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="SecBg"
                                                                Storyboard.TargetProperty="Color"
                                                                To="#F2ECE3" Duration="0:0:0.18"/>
                                                <ColorAnimation Storyboard.TargetName="SecBorder"
                                                                Storyboard.TargetProperty="Color"
                                                                To="#E5DDD4" Duration="0:0:0.18"/>
                                            </Storyboard>
                                        </VisualState>

                                        <VisualState x:Name="PointerOver">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="SecBg"
                                                                Storyboard.TargetProperty="Color"
                                                                To="#E8E0D5" Duration="0:0:0.15"/>
                                                <ColorAnimation Storyboard.TargetName="SecBorder"
                                                                Storyboard.TargetProperty="Color"
                                                                To="#C6BCB3" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </VisualState>

                                        <VisualState x:Name="Pressed">
                                            <Storyboard>
                                                <ColorAnimation Storyboard.TargetName="SecBg"
                                                                Storyboard.TargetProperty="Color"
                                                                To="#D8CFC5" Duration="0:0:0.07"/>
                                            </Storyboard>
                                        </VisualState>

                                    </VisualStateGroup>
                                </VisualStateManager.VisualStateGroups>

                                <Border CornerRadius="9" Padding="16,8"
                                        BorderThickness="1">
                                    <Border.Background>
                                        <SolidColorBrush x:Name="SecBg" Color="#F2ECE3"/>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush x:Name="SecBorder" Color="#E5DDD4"/>
                                    </Border.BorderBrush>
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center"
                                                      Foreground="#292524"
                                                      FontSize="{TemplateBinding FontSize}"
                                                      FontWeight="{TemplateBinding FontWeight}"
                                                      Content="{TemplateBinding Content}"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </Grid.Resources>

        <ScrollViewer x:Name="AuthPanel"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalAlignment="Stretch">

            <Grid VerticalAlignment="Center"
                  HorizontalAlignment="Center"
                  Width="440"
                  Margin="24,60">

                <Border CornerRadius="24" Background="#D4C9BF"
                        Margin="6,12,-6,-12" Opacity="0.18"/>
                <Border CornerRadius="24" Background="#D4C9BF"
                        Margin="3,6,-3,-6" Opacity="0.22"/>

                <Border Background="#FFFFFF"
                        CornerRadius="22"
                        BorderBrush="#E8E0D6"
                        BorderThickness="1"
                        Padding="44,42">

                    <StackPanel Spacing="0">

                        <StackPanel HorizontalAlignment="Center"
                                    Margin="0,0,0,34">
                            <TextBlock Text="🌿"
                                       FontSize="38"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="takent"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#1A1210"
                                       HorizontalAlignment="Center"
                                       CharacterSpacing="-30"/>
                            <TextBlock x:Name="AuthSubtitle"
                                       Text="Inicia sesión en tu cuenta"
                                       FontSize="14"
                                       Foreground="#7A7370"
                                       HorizontalAlignment="Center"
                                       Margin="0,5,0,0"/>
                        </StackPanel>

                        <Border Background="#F2ECE3"
                                CornerRadius="13"
                                Padding="4"
                                Margin="0,0,0,32">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="LoginTabIndicator"
                                        Grid.Column="0"
                                        Background="#292524"
                                        CornerRadius="10"/>

                                <Border x:Name="RegisterTabIndicator"
                                        Grid.Column="1"
                                        Background="Transparent"
                                        CornerRadius="10"/>

                                <Button x:Name="LoginTabBtn"
                                        Grid.Column="0"
                                        Content="Iniciar Sesión"
                                        Foreground="#FFF7ED"
                                        FontWeight="SemiBold"
                                        Style="{StaticResource TabBtn}"
                                        Click="LoginTabBtn_Click"/>

                                <Button x:Name="RegisterTabBtn"
                                        Grid.Column="1"
                                        Content="Registrarse"
                                        Foreground="#7A7370"
                                        Style="{StaticResource TabBtn}"
                                        Click="RegisterTabBtn_Click"/>
                            </Grid>
                        </Border>

                        <StackPanel x:Name="LoginForm" Spacing="20">

                            <StackPanel>
                                <TextBlock Text="Email"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="LoginEmailBox"
                                         PlaceholderText="tu@email.com"
                                         Style="{StaticResource InputBox}"
                                         KeyDown="Input_KeyDown"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Contraseña"
                                           Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="LoginPasswordBox"
                                             PlaceholderText="••••••••"
                                             Style="{StaticResource PassBox}"
                                             KeyDown="Input_KeyDown"/>
                            </StackPanel>

                            <Button x:Name="LoginBtn"
                                    Content="Iniciar Sesión"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,8,0,0"
                                    Click="LoginBtn_Click"/>
                        </StackPanel>

                        <StackPanel x:Name="RegisterForm"
                                    Visibility="Collapsed"
                                    Spacing="20">

                            <StackPanel>
                                <TextBlock Text="Nombre de usuario"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="RegisterUsernameBox"
                                         PlaceholderText="tunombre"
                                         Style="{StaticResource InputBox}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Email"
                                           Style="{StaticResource FieldLabel}"/>
                                <TextBox x:Name="RegisterEmailBox"
                                         PlaceholderText="tu@email.com"
                                         Style="{StaticResource InputBox}"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Contraseña"
                                           Style="{StaticResource FieldLabel}"/>
                                <PasswordBox x:Name="RegisterPasswordBox"
                                             PlaceholderText="••••••••"
                                             Style="{StaticResource PassBox}"/>
                            </StackPanel>

                            <Button x:Name="RegisterBtn"
                                    Content="Crear cuenta"
                                    Style="{StaticResource PrimaryBtn}"
                                    Margin="0,8,0,0"
                                    Click="RegisterBtn_Click"/>
                        </StackPanel>

                        <StackPanel x:Name="LoadingPanel"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="10"
                                    Visibility="Collapsed"
                                    Margin="0,26,0,0">
                            <ProgressRing IsActive="True"
                                          Width="18" Height="18"
                                          Foreground="#292524"/>
                            <TextBlock Text="Conectando…"
                                       Foreground="#7A7370"
                                       VerticalAlignment="Center"
                                       FontSize="13"/>
                        </StackPanel>

                        <Border x:Name="ErrorBorder"
                                Background="#FDF0EE"
                                CornerRadius="11"
                                BorderBrush="#D97B6C"
                                BorderThickness="1"
                                Padding="14,12"
                                Margin="0,22,0,0"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="⚠"
                                           Foreground="#B55A4A"
                                           VerticalAlignment="Top"
                                           FontSize="14"
                                           Margin="0,1,0,0"/>
                                <TextBlock x:Name="ErrorMsg"
                                           Foreground="#8F3E30"
                                           FontSize="13"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Grid x:Name="HomePanel" Visibility="Collapsed">
            <Grid.Resources>
                <DataTemplate x:Key="PostCardTemplate">
                    <Border Background="#FFFFFF"
                    CornerRadius="16"
                    BorderBrush="#EBE3DA"
                    BorderThickness="1"
                    Padding="24,20"
                    Margin="0,0,0,14">
                        <StackPanel Spacing="12">

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding AuthorDisplay}"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#1A1210"/>
                                    <TextBlock Text="{Binding UsernameDisplay}"
                                       FontSize="12"
                                       Foreground="#9E9994"
                                       Margin="0,2,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="1"
                                   Text="{Binding DateDisplay}"
                                   FontSize="12"
                                   Foreground="#B8B3B0"
                                   VerticalAlignment="Top"/>
                            </Grid>

                            <Border Height="1"
                            Background="#F0EAE2"
                            Margin="-24,0"/>

                            <TextBlock Text="{Binding Content}"
                               FontSize="14"
                               Foreground="#292524"
                               TextWrapping="Wrap"
                               LineHeight="22"/>

                            <TextBlock Text="{Binding HashtagsDisplay}"
                               FontSize="12"
                               Foreground="#8A6F5E"
                               FontWeight="Medium"
                               TextWrapping="Wrap"
                               Visibility="{Binding HashtagsDisplay,
                                   Converter={StaticResource StringToVisibilityConverter}}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>

            </Grid.Resources>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
            Background="#FFFFFF"
            BorderBrush="#EBE3DA"
            BorderThickness="0,0,0,1"
            Padding="28,14">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center">
                        <TextBlock Text="🌿" FontSize="20"/>
                        <TextBlock Text="takent"
                           FontSize="17"
                           FontWeight="Bold"
                           Foreground="#1A1210"
                           VerticalAlignment="Center"
                           CharacterSpacing="-30"/>
                    </StackPanel>

                    <Button x:Name="LogoutBtn"
                    Content="Cerrar sesión"
                    Style="{StaticResource SecondaryBtn}"
                    HorizontalAlignment="Right"
                    Click="LogoutBtn_Click"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

                <StackPanel MaxWidth="640"
                    HorizontalAlignment="Center"
                    Margin="24,32,24,40"
                    Spacing="0">

                    <Border Background="#FFFFFF"
                    CornerRadius="18"
                    BorderBrush="#EBE3DA"
                    BorderThickness="1"
                    Padding="24,22"
                    Margin="0,0,0,28">
                        <StackPanel Spacing="14">

                            <TextBlock Text="¿Qué estás pensando?"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#1A1210"/>

                            <TextBox x:Name="PostContentBox"
                             PlaceholderText="Escribe tu post… usa #hashtags para etiquetarlo"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="100"
                             MaxHeight="220"
                             Style="{StaticResource InputBox}"
                             VerticalAlignment="Top"/>

                            <Grid>
                                <TextBlock x:Name="CharCounter"
                                   Text="0 / 500"
                                   FontSize="12"
                                   Foreground="#B8B3B0"
                                   VerticalAlignment="Center"/>

                                <Button x:Name="CreatePostBtn"
                                Content="Publicar"
                                HorizontalAlignment="Right"
                                MinWidth="110"
                                HorizontalContentAlignment="Center"
                                Style="{StaticResource PrimaryBtn}"
                                Click="CreatePostBtn_Click"/>
                            </Grid>

                            <Border x:Name="PostErrorBorder"
                            Background="#FDF0EE"
                            CornerRadius="10"
                            BorderBrush="#D97B6C"
                            BorderThickness="1"
                            Padding="12,10"
                            Visibility="Collapsed">
                                <TextBlock x:Name="PostErrorMsg"
                                   Foreground="#8F3E30"
                                   FontSize="13"
                                   TextWrapping="Wrap"/>
                            </Border>

                            <StackPanel x:Name="PostLoadingPanel"
                                Orientation="Horizontal"
                                Spacing="8"
                                Visibility="Collapsed">
                                <ProgressRing IsActive="True"
                                      Width="16" Height="16"
                                      Foreground="#292524"/>
                                <TextBlock Text="Publicando…"
                                   Foreground="#7A7370"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <TextBlock Text="Muro"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#1A1210"
                       Margin="0,0,0,18"/>

                    <StackPanel x:Name="FeedLoadingPanel"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Spacing="10"
                        Visibility="Collapsed"
                        Margin="0,20,0,0">
                        <ProgressRing IsActive="True"
                              Width="20" Height="20"
                              Foreground="#292524"/>
                        <TextBlock Text="Cargando posts…"
                           Foreground="#7A7370"
                           FontSize="13"
                           VerticalAlignment="Center"/>
                    </StackPanel>

                    <Border x:Name="FeedErrorBorder"
                    Background="#FDF0EE"
                    CornerRadius="10"
                    BorderBrush="#D97B6C"
                    BorderThickness="1"
                    Padding="14,12"
                    Visibility="Collapsed"
                    Margin="0,0,0,16">
                        <TextBlock x:Name="FeedErrorMsg"
                           Foreground="#8F3E30"
                           FontSize="13"
                           TextWrapping="Wrap"/>
                    </Border>

                    <StackPanel x:Name="EmptyFeedPanel"
                        HorizontalAlignment="Center"
                        Spacing="8"
                        Visibility="Collapsed"
                        Margin="0,40,0,0">
                        <TextBlock Text="🌱"
                           FontSize="40"
                           HorizontalAlignment="Center"/>
                        <TextBlock Text="Aún no hay posts."
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#7A7370"
                           HorizontalAlignment="Center"/>
                        <TextBlock Text="¡Sé el primero en publicar algo!"
                           FontSize="13"
                           Foreground="#B8B3B0"
                           HorizontalAlignment="Center"/>
                    </StackPanel>

                    <ItemsControl x:Name="PostsList"
                          ItemTemplate="{StaticResource PostCardTemplate}"/>

                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>
</Window>